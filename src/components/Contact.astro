---
// Astro wrapper for Contact section with React island for the form
import ContactForm from "./ContactForm";
---

<section id="contact" class="py-20 bg-gray-800">
    <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
            <h2
                class="text-3xl md:text-4xl font-bold text-center mb-12 text-white"
            >
                Get In <span class="text-rose-400">Touch</span>
            </h2>

            <div class="grid md:grid-cols-2 gap-12">
                <div class="space-y-8">
                    <div>
                        <h3 class="text-xl font-semibold text-rose-400 mb-4">
                            Let's work together
                        </h3>
                        <p class="text-gray-200 leading-relaxed">
                            I'm always interested in new opportunities and
                            exciting projects. Whether you have a project in
                            mind or just want to chat about technology, feel
                            free to reach out!
                        </p>
                    </div>

                    <div class="space-y-4">
                        <div class="flex items-center space-x-4">
                            <div
                                class="w-10 h-10 bg-rose-400/10 rounded-lg flex items-center justify-center"
                            >
                                <span class="text-rose-400 text-lg">📧</span>
                            </div>
                            <div>
                                <p class="text-gray-200 text-sm">Email</p>
                                <a
                                    href="mailto:andhikahutama9@gmail.com"
                                    class="text-gray-200 hover:text-rose-400 transition-colors"
                                >
                                    andhikahutama9@gmail.com
                                </a>
                            </div>
                        </div>

                        <div class="flex items-center space-x-4">
                            <div
                                class="w-10 h-10 bg-rose-400/10 rounded-lg flex items-center justify-center"
                            >
                                <span class="text-rose-400 text-lg">📱</span>
                            </div>
                            <div>
                                <p class="text-gray-200 text-sm">Phone</p>
                                <a
                                    href="tel:+1234567890"
                                    class="text-gray-200 hover:text-rose-400 transition-colors"
                                >
                                    +62 823 1018 0884
                                </a>
                            </div>
                        </div>

                        <div class="flex items-center space-x-4">
                            <div
                                class="w-10 h-10 bg-rose-400/10 rounded-lg flex items-center justify-center"
                            >
                                <span class="text-rose-400 text-lg">📍</span>
                            </div>
                            <div>
                                <p class="text-gray-200 text-sm">Location</p>
                                <p class="text-gray-200">Indonesia</p>
                            </div>
                        </div>
                    </div>

                    <div class="flex space-x-4 pt-4">
                        <a
                            href="https://github.com/fadd00"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="w-10 h-10 bg-gray-700 hover:bg-rose-400 rounded-lg flex items-center justify-center transition-colors group"
                        >
                            <span
                                class="text-gray-200 group-hover:text-gray-900"
                                >🐙</span
                            >
                        </a>
                        <a
                            href="https://id.linkedin.com/in/andhika-hutama-9181b8283"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="w-10 h-10 bg-gray-700 hover:bg-rose-400 rounded-lg flex items-center justify-center transition-colors group"
                        >
                            <span
                                class="text-gray-200 group-hover:text-gray-900"
                                >💼</span
                            >
                        </a>
                        <a
                            href="https://www.instagram.com/dhikaarch/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="w-10 h-10 bg-gray-700 hover:bg-rose-400 rounded-lg flex items-center justify-center transition-colors group"
                        >
                            <span
                                class="text-gray-200 group-hover:text-gray-900"
                                >📷</span
                            >
                        </a>
                    </div>
                </div>

                <ContactForm client:load />
            </div>
        </div>
    </div>
</section>
