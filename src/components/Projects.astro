---
// Astro projects section
---

<section id="projects" class="py-20 bg-gray-900">
    <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-white">
                Featured <span class="text-rose-400">Projects</span>
            </h2>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                {/* Project Card Placeholder */}
                <div class="bg-gray-800 rounded-lg overflow-hidden border border-gray-700 hover:border-rose-400 transition-colors group">
                    <div class="p-6">
                        <h3 class="text-xl font-bold text-white mb-3 group-hover:text-rose-400 transition-colors">
                            Project Name
                        </h3>
                        <p class="text-gray-300 mb-4 line-clamp-3">
                            A description of the project goes here. It explains what it does, why it was built, and the technologies used.
                        </p>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <span class="px-3 py-1 bg-gray-700 text-rose-300 text-sm rounded-full">Astro</span>
                            <span class="px-3 py-1 bg-gray-700 text-rose-300 text-sm rounded-full">React</span>
                            <span class="px-3 py-1 bg-gray-700 text-rose-300 text-sm rounded-full">Tailwind</span>
                        </div>
                    </div>
                </div>
                {/* Add more projects here as needed */}
            </div>
        </div>
    </div>
</section>
